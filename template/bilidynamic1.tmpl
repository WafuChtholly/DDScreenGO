                                    {{if $oArc.stat}}
                                        {{if $oArc.stat.play}}<span class="video-stat"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>{{$oArc.stat.play}}</span>{{end}}
                                        {{if $oArc.stat.danmaku}}<span class="video-stat"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>{{$oArc.stat.danmaku}}</span>{{end}}
                                    {{end}}
                                </div>
                            </div>
                        </a>
                    {{else if $oDynamic.major.article}}
