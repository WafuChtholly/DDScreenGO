                        {{- else -}}
                            <span>{{$oDynamic.desc.text}}</span>
                        {{- end -}}
                    {{- end -}}
                </div>
                
                <!-- 原动态图片 -->
                {{if $oDynamic.major}}
                    {{if $oDynamic.major.draw}}
                        {{if $oDynamic.major.draw.items}}
                        {{if $.Expand}}
                        <div class="image-grid expand-img">
                            {{range $pic := $oDynamic.major.draw.items}}
                                <img src="{{$pic.src}}" />
                            {{end}}
                        </div>
                        {{else}}
                        <div class="image-grid {{if eq (len $oDynamic.major.draw.items) 1}}single-img{{end}}">
                            {{range $index, $pic := $oDynamic.major.draw.items}}
                                {{if lt $index 9}}
                                <img src="{{$pic.src}}@400w_400h_1c.webp" />
                                {{end}}
                            {{end}}
                        </div>
                        {{end}}
                        {{end}}
                    {{end}}
                {{end}}

                <!-- 原动态附加卡片 -->
                {{if $oDynamic.additional}}
                    {{if $oDynamic.additional.vote}}
                    {{$oVote := $oDynamic.additional.vote}}
                    <div class="vote-box">
                        <div class="vote-desc">📊 {{$oVote.desc}}</div>
                        {{if $oVote.options}}
                            {{range $opt := $oVote.options}}
                            <div class="vote-option">
                                <div class="vote-progress" style="width: 0%;"></div>
                                <span class="vote-opt-desc">{{$opt.opt_desc}}</span>
                                <span class="vote-opt-pct">{{if $opt.cnt}}{{$opt.cnt}} 票{{end}}</span>
                            </div>
                            {{end}}
                        {{end}}
                        <div class="vote-meta">{{if $oVote.join_num}}{{$oVote.join_num}} 人参与{{end}}</div>
                    </div>
                    {{end}}

                    {{if $oDynamic.additional.reserve}}
                    {{$res := $oDynamic.additional.reserve}}
                    <div class="reserve-box">
                        <div class="reserve-info">
                            <div class="reserve-title">📅 {{$res.title}}</div>
                            <div class="reserve-desc">
                                {{if $res.desc1}}{{$res.desc1.text}}{{end}}
                                {{if $res.desc2}} | {{$res.desc2.text}}{{end}}
                            </div>
                        </div>
                        <div class="reserve-btn">预约</div>
                    </div>
                    {{end}}
                {{end}}
            </div>
            {{end}}
        {{end}}
        
    </div>
    {{end}}
