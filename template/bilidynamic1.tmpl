                    <div class="video-cover-wrap">
                        <img class="video-cover" src="{{$arc.cover}}" referrerpolicy="no-referrer" />
                        {{if $arc.duration_text}}<span class="video-duration">{{$arc.duration_text}}</span>{{end}}
                    </div>
                    <div class="video-info">
                        {{if $arc.type_name}}<span class="video-type-badge">投稿了{{$arc.type_name}}</span>{{end}}
