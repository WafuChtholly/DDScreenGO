                <div class="image-grid expand-img">
                    {{range $pic := $dynamic.major.draw.items}}
                        <img src="{{$pic.src}}" />
                    {{end}}
                </div>
                {{else}}
                <div class="image-grid {{if eq (len $dynamic.major.draw.items) 1}}single-img{{end}}">
                    {{range $index, $pic := $dynamic.major.draw.items}}
                        {{if lt $index 9}}
                        <img src="{{$pic.src}}@400w_400h_1c.webp" />
                        {{end}}
                    {{end}}
                </div>
                {{end}}
                {{end}}
            {{end}}
        {{end}}

        <!-- ================= 4. 附加卡片 (投票/预约等) ================= -->
        {{if $dynamic.additional}}
            {{if $dynamic.additional.vote}}
            {{$vote := $dynamic.additional.vote}}
            <div class="vote-box">
                <div class="vote-desc">📊 {{$vote.desc}}</div>
                {{if $vote.options}}
                    {{range $opt := $vote.options}}
                    <div class="vote-option">
                        <!-- 原始JSON无法直接在模板计算百分比，保留底色条但宽度固定或取消 -->
                        <div class="vote-progress" style="width: 0%;"></div>
                        <span class="vote-opt-desc">{{$opt.desc}}</span>
                        <span class="vote-opt-pct">{{if $opt.cnt}}{{$opt.cnt}} 票{{end}}</span>
                    </div>
                    {{end}}
                {{end}}
                <div class="vote-meta">{{if $vote.join_num}}{{$vote.join_num}} 人参与{{end}}</div>
            </div>
            {{end}}

            {{if $dynamic.additional.reserve}}
            {{$res := $dynamic.additional.reserve}}
