<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>Bilibili Dynamic Template</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700;800&display=swap');
        :root {
            --bg-color: #f4f5f7;
            --card-bg: #ffffff;
            --text-main: #18191c;
            --text-sub: #9499a0;
            --bili-blue: #00a1d6;
            --bili-pink: #fb7299;
            --border-color: #e3e5e7;
            --forward-bg: #f1f2f3;
        }
        
        body {
            background-color: var(--bg-color);
            font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
            margin: 0;
            padding: 30px;
            display: inline-block;
            min-width: 100%;
            box-sizing: border-box;
        }
        
        .dynamic-card {
            width: 650px;
            margin: 0 auto;
            background: var(--card-bg);
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.06);
            padding: 24px;
            box-sizing: border-box;
        }

        .header {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
        }
        .avatar-wrap {
            width: 48px;
            height: 48px;
            margin-right: 14px;
            flex-shrink: 0;
        }
        .avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 1px solid var(--border-color);
        }
        .user-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .name-row {
            display: flex;
            align-items: center;
            margin-bottom: 4px;
        }
        .name {
            font-size: 16px;
            font-weight: 600;
            color: var(--bili-pink);
        }
        .time {
            font-size: 12px;
            color: var(--text-sub);
        }
        .fan-card {
            position: relative;
            display: inline-flex;
            align-items: center;
            height: 22px;
            margin-left: 8px;
            vertical-align: middle;
        }
        .fan-card-bg {
            height: 100%;
            width: auto;
            object-fit: contain;
        }
        .fan-card-num {
            position: absolute;
            left: 14%;
            top: 50%;
            transform: translateY(-50%);
            font-size: 12px;
            font-weight: bold;
            font-family: 'Bahnschrift', 'DIN Alternate', 'DIN Condensed', 'Impact', sans-serif;
            font-stretch: condensed;
            letter-spacing: 0.5px;
            text-shadow: 0.5px 0.5px 0px rgba(255,255,255,0.8), -0.5px -0.5px 0px rgba(255,255,255,0.8);
        }

        .content {
            font-size: 15px;
            line-height: 1.7;
            color: var(--text-main);
            margin-bottom: 16px;
            word-wrap: break-word;
            white-space: pre-wrap;
        }
        .bili-link {
            color: var(--bili-blue);
            text-decoration: none;
            cursor: pointer;
        }
        .bili-emoji {
            width: 20px;
            height: 20px;
            vertical-align: text-bottom;
            margin: 0 2px;
        }
        .bili-emoji-large {
            width: 60px;
            height: 60px;
            display: inline-block;
            vertical-align: text-bottom;
            margin: 0 4px;
        }

        .image-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
            margin-bottom: 16px;
        }
        .image-grid.single-img {
            grid-template-columns: 1fr;
        }
        .image-grid.single-img img {
            max-width: 60%;
            height: auto;
            max-height: 400px;
        }
        .image-grid.expand-img {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .image-grid.expand-img img {
            width: 100%;
            height: auto;
            aspect-ratio: auto;
            object-fit: contain;
            border-radius: 8px;
        }
        .image-grid img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            object-position: top;
            border-radius: 6px;
            border: 1px solid rgba(0,0,0,0.05);
        }

        .title {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-main);
            margin: 16px 0;
            line-height: 1.5;
        }

        .forward-box {
            background: var(--forward-bg);
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
        }
        .forward-name {
            color: var(--bili-blue);
            font-weight: bold;
            margin-bottom: 10px;
            font-size: 14px;
        }
        .vote-box {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }
        .vote-desc {
            font-weight: bold;
            color: var(--text-main);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
        }
        .vote-option {
            background: #fff;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            margin-bottom: 8px;
            position: relative;
            overflow: hidden;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
        }
        .vote-progress {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            background: linear-gradient(90deg, rgba(251,114,153,0.15), rgba(251,114,153,0.3));
        }
        .vote-opt-desc {
            font-size: 14px;
            color: var(--text-main);
            font-weight: 500;
        }
        .vote-opt-pct {
            font-size: 13px;
            color: var(--bili-blue);
        }
        .vote-meta {
            font-size: 12px;
            color: var(--text-sub);
            margin-top: 8px;
        }
        .reserve-box {
            background: #fdf6f9;
            border: 1px solid #f8e3eb;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .reserve-info {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .reserve-title {
            font-size: 15px;
            font-weight: bold;
            color: var(--bili-pink);
        }
        .reserve-desc {
            font-size: 13px;
            color: var(--text-sub);
        }
        .reserve-btn {
            background: var(--bili-pink);
            color: white;
            padding: 6px 16px;
            border-radius: 4px;
            font-size: 13px;
            font-weight: bold;
        }

        .video-card {
            display: flex;
            align-items: flex-start;
            background: #f6f7f8;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 16px;
            text-decoration: none;
            color: inherit;
            border: 1px solid var(--border-color);
        }
        .video-cover-wrap {
            position: relative;
            width: 220px;
            aspect-ratio: 16 / 9;
            flex-shrink: 0;
            overflow: hidden;
        }
        .video-cover {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .video-duration {
            position: absolute;
            bottom: 6px;
            right: 6px;
            background: rgba(0,0,0,0.72);
            color: #fff;
            font-size: 12px;
            padding: 2px 6px;
            border-radius: 4px;
            font-variant-numeric: tabular-nums;
        }
        .video-info {
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            flex: 1;
            min-width: 0;
        }
        .video-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 6px;
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .video-desc-text {
            font-size: 13px;
            color: var(--text-sub);
            margin-bottom: 8px;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .video-stats {
            display: flex;
            gap: 16px;
            font-size: 12px;
            color: var(--text-sub);
        }
        .video-stat {
            display: flex;
            align-items: center;
            gap: 3px;
        }
        .video-stat svg {
            width: 14px;
            height: 14px;
            fill: currentColor;
            flex-shrink: 0;
        }
        .video-type-badge {
            display: inline-block;
            background: #e3f2fd;
            color: var(--bili-blue);
            font-size: 11px;
            padding: 1px 6px;
            border-radius: 3px;
            margin-bottom: 6px;
        }
    </style>
</head>
<body>
    <!-- 引入扁平化后的简单数据结构，让模板编写更加直观 -->
    {{$item := .RawData.data.item}}
    
    {{if not $item}}
    <div class="dynamic-card" style="text-align: center; color: var(--bili-pink); padding: 50px 20px;">
        <h2 style="margin-bottom: 10px;">获取动态数据失败</h2>
        <p style="color: var(--text-sub); font-size: 14px;">这可能是因为该动态已被删除、设为仅粉丝可见，或是 B 站接口触发了风控限制(-352等)。</p>
    </div>
    {{else}}
    <div class="dynamic-card">
        <!-- ================= 1. 头部信息 ================= -->
        {{$author := $item.modules.module_author}}
        <div class="header">
            <div class="avatar-wrap">
                <img class="avatar" src="{{$author.face}}" alt="avatar">
            </div>
            <div class="user-info">
                <div class="name-row">
                    <span class="name">{{$author.name}}</span>
                    
                    <!-- 判断是否有粉丝专属卡片 -->
                    {{if $author.decorate}}
                        {{if $author.decorate.fan}}
                        <div class="fan-card">
                            <img class="fan-card-bg" src="{{$author.decorate.card_url}}" />
                            <span class="fan-card-num" style="color: {{$author.decorate.fan.color}}">
                                {{$author.decorate.fan.num_str}}
                            </span>
                        </div>
                        {{end}}
                    {{end}}
                </div>
                <div class="time">{{$author.pub_time}}</div>
            </div>
        </div>

        <!-- ================= 2. 标题 ================= -->
        {{$dynamic := $item.modules.module_dynamic}}
        {{if $dynamic.major}}
            {{if $dynamic.major.article}}
                <div class="title">{{$dynamic.major.article.title}}</div>
            {{end}}
        {{end}}

        <!-- ================= 2.1 话题标签 ================= -->
        {{if $dynamic.topic}}
            {{if $dynamic.topic.name}}
            <div style="margin-bottom: 12px;">
                <span class="bili-link" style="display:inline-flex; align-items:center; gap: 4px; font-size: 14px;">
                    <svg viewBox="0 0 16 16" style="width: 14px; height: 14px; fill: currentColor;"><path d="M5.19 0.99C4.91 1.19 4.84 1.58 5.04 1.86L6.11 3.39C6.31 3.67 6.70 3.74 6.98 3.54C7.26 3.35 7.33 2.96 7.13 2.67L6.06 1.14C5.86 0.86 5.47 0.79 5.19 0.99zM10.81 0.99C10.53 0.79 10.14 0.86 9.94 1.14L8.87 2.67C8.67 2.96 8.74 3.35 9.02 3.54C9.30 3.74 9.69 3.67 9.89 3.39L10.96 1.86C11.16 1.58 11.09 1.19 10.81 0.99zM8 2.56C6.50 2.56 5.17 2.62 4.20 2.68C2.92 2.76 1.90 3.74 1.81 5.03C1.75 5.75 1.71 6.65 1.71 7.63C1.71 8.60 1.75 9.50 1.81 10.22C1.90 11.48 2.90 12.46 4.15 12.55C5.10 12.62 6.40 12.69 7.88 12.69C8.38 13.17 9.43 14.08 10.66 14.64C11.01 14.80 11.43 14.86 11.74 14.58C12.04 14.30 12.02 13.88 11.92 13.52C11.81 13.16 11.76 12.82 11.73 12.56C13.01 12.47 14.09 11.54 14.19 10.22C14.25 9.50 14.29 8.60 14.29 7.63C14.29 6.65 14.25 5.75 14.19 5.03C14.10 3.74 13.08 2.76 11.80 2.68C10.83 2.62 9.50 2.56 8 2.56z" fill="currentColor"></path></svg>
                    <span>{{$dynamic.topic.name}}</span>
                </span>
            </div>
            {{end}}
        {{end}}

        <!-- ================= 2.2 动态主文本 ================= -->

        <div class="content">
            {{- if $dynamic.desc -}}
                {{- if $dynamic.desc.rich_text_nodes -}}
                    {{- range $node := $dynamic.desc.rich_text_nodes -}}
                        {{- if eq $node.type "RICH_TEXT_NODE_TYPE_TEXT" -}}
                            <span>{{$node.text}}</span>
                        {{- else if eq $node.type "RICH_TEXT_NODE_TYPE_AT" -}}
                            <span class="bili-rich-text-module at bili-link" data-oid="{{$node.rid}}">@{{$node.text}}</span>
                        {{- else if eq $node.type "RICH_TEXT_NODE_TYPE_TOPIC" -}}
                            <span class="bili-link" style="display:inline-flex; align-items:center; gap: 4px;">
